    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n    const data = item.json;\n\n    // 1. Extracción de datos\n    const ia_riesgo = data.riesgo ? Number(data.riesgo) : 0;\n    const ia_clase = data.ia_clase || \"N/A\";\n    const vt_maliciosos = data.vt_maliciosos ? Number(data.vt_maliciosos) : 0;\n    const es_reincidente = data.recurrente === true;\n    const indicadores = Array.isArray(data.indicadores) ? data.indicadores : [];\n    const texto = (data.contenido_texto || \"\").toLowerCase();\n\n    // 2. Cálculo de \"Score de Amenaza\"\n    let scoreFinal = ia_riesgo;\n\n    // REGLA: Solo procesar indicadores reales\n    if (indicadores.length > 0) {\n        scoreFinal = Math.max(scoreFinal, 0.65);\n        scoreFinal += 0.10;\n    }\n\n    // PENALIZACIÓN POR PALABRAS CRÍTICAS (Solo si el texto es largo o sospechoso)\n    const keywords = ['bitcoin', 'pago', 'transferencia', 'hacker', 'policía', 'video', 'cámara'];\n    if (keywords.some(word => texto.includes(word)) && texto.length > 3) {\n        scoreFinal += 0.15;\n    }\n\n    // --- CAMBIO CLAVE AQUÍ ---\n    // Solo penalizamos la reincidencia si el riesgo detectado ya es moderado (> 0.6)\n    // o si hay indicadores presentes. Si el usuario dice \"hola\", no se penaliza.\n    if (es_reincidente && (ia_riesgo > 0.6 || indicadores.length > 0)) {\n        scoreFinal += 0.20;\n    }\n\n    // PRIORIDAD VIRUSTOTAL (Esto manda sobre todo)\n    if (vt_maliciosos >= 1) {\n        scoreFinal = Math.max(scoreFinal, 0.85);\n        if (vt_maliciosos >= 3) scoreFinal = 1.0;\n    }\n\n    // 3. Sistema de Veredictos\n    let veredicto = \"PERMITIR\";\n    let clasificacion = \"legit\";\n\n    // Si el texto es muy corto (como \"hola\") y no tiene links ni VT maliciosos, \n    // forzamos el veredicto a PERMITIR aunque el score sea alto por ruido.\n    const es_texto_trivial = texto.length < 5 && vt_maliciosos === 0 && indicadores.length === 0;\n\n    if (!es_texto_trivial) {\n        if (scoreFinal >= 0.85) {\n            veredicto = \"BLOQUEAR_Y_ELIMINAR\";\n            clasificacion = \"phishing_critico\";\n        } \n        else if (scoreFinal >= 0.70) { // Subimos el umbral de sospecha a 0.70\n            veredicto = \"ELIMINAR_MENSAJE\";\n            clasificacion = \"phishing_sospechoso\";\n        }\n    }\n\n    scoreFinal = Math.min(Math.max(scoreFinal, 0), 1.0);\n\n    return {\n        json: {\n            chat_id: data.chat_id,\n            mensaje_id: parseInt(data.mensaje_id) || 0,\n            veredicto_final: veredicto,\n            clasificacion: clasificacion,\n            riesgo_score: parseFloat(scoreFinal.toFixed(2)),\n            detalles: {\n                ia_base: ia_riesgo,\n                ia_clase: ia_clase,\n                indicadores: indicadores,\n                indicadores_conteo: indicadores.length,\n                es_reincidente: es_reincidente,\n                vt_detecciones: vt_maliciosos,\n                trivial: es_texto_trivial\n            }\n        }\n    };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
