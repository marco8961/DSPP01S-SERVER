    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  // Accedemos a la zona donde están los motores (DNS8, URLQuery, etc.)\n  const attributes = item.json?.data?.attributes || {};\n  const stats = attributes.last_analysis_stats || attributes.stats;\n  const results = attributes.last_analysis_results || attributes.results;\n\n  // 1. Calculamos el Score Total\n  const maliciosos = stats?.malicious || 0;\n  const total = stats ? (stats.malicious + stats.harmless + stats.suspicious + stats.undetected) : 0;\n\n  // 2. Filtramos motores específicos para el \"Resumen\"\n  // Aquí puedes agregar los que más te importen\n  const motoresInteres = ['Google Safe Browsing', 'Kaspersky', 'Sophos', 'DNS8', 'URLQuery'];\n  let resumenMotores = \"\";\n\n  if (results) {\n    motoresInteres.forEach(m => {\n      if (results[m]) {\n        // Guardamos el nombre del motor y si dijo 'clean', 'malicious', etc.\n        resumenMotores += `${m}: ${results[m].result}; `;\n      }\n    });\n  }\n\n  // 3. Resultado final para Postgres\n  return {\n    json: {\n      vt_maliciosos: maliciosos,\n      vt_score: `${maliciosos}/${total}`,\n      vt_veredicto: maliciosos > 0 ? 'MALICIOSO' : 'SEGURO',\n      vt_detalle_motores: resumenMotores || \"Motores principales sin alertas\",\n      url_final: attributes.url || item.json.meta?.url_info?.url\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ],
      "id": "b1e9522e-f5a9-406e-96b1-0f1e437b5710",
      "name": "limpia los resultados"
    },
    {
      "parameters": {
        "jsCode": "// 1. Accedemos a los datos que vienen del Merge2\nconst inputData = $input.item.json;\n\n// 2. Accedemos a los datos del nodo Resultados (urlscan.io)\nconst res = $node[\"Resultados\"].json;\n\nreturn {\n    fecha: new Date().toISOString(),\n    \n    // --- SOLUCIÓN AQUÍ ---\n    // En tu captura se ve que la llave es \"message_id\". \n    // Usamos ambas por si acaso cambia en el futuro.\n    mensaje_id: inputData.message_id || inputData.mensaje_id || \"ID no disponible\",\n    \n    // Usamos \"mensaje\" que es como viene del nodo anterior según tu captura\n    url_original: inputData.mensaje || res.page?.url || \"URL no disponible\",\n    url_final: res.task?.url || \"URL no disponible\",\n    \n    us_puntuacion: res.verdicts?.overall?.score ? Number(res.verdicts.overall.score) : 0,\n    us_malicioso: res.verdicts?.overall?.malicious || false,\n    us_veredicto: res.verdicts?.overall?.malicious ? 'MALICIOSO' : 'SEGURO',\n    \n    score_vt: 0,\n    captura_url: res.task?.screenshotURL || \"Sin captura\",\n    status_http: String(res.page?.status || \"0\"),\n    ip_servidor: res.page?.ip || \"Desconocida\",\n    pais: res.page?.country || \"Desconocido\",\n    tecnologias: res.page?.server || \"N/A\"\n};"
      },
