    {
      "parameters": {
        "jsCode": "const item = $input.item;\n\n// 1. Obtener datos directamente del body que manda el Interceptor\nconst datos = item.json.body || {}; \n\n// 2. Extraer información usando los campos exactos del payload de Python\nconst mensajeOriginal = datos.contenido_texto || \"\";\nconst linksRescatados = datos.links || [];\nconst tieneLinks = datos.has_links || linksRescatados.length > 0;\n\n// Ajuste de IDs según el nuevo script unificado\nconst nombreUsuario = datos.username || \"Desconocido\";\nconst chatId = datos.chat_id || \"0\"; // Usamos chat_id (grupo o user)\nconst mensajeId = datos.message_id || \"N/A\";\n\n// --- MEJORA: LIMPIEZA DE TEXTO PARA LA IA ---\nlet textoLimpio = mensajeOriginal.toLowerCase();\n\n// Reemplazar URLs por [url] para simplificar el análisis de la IA\ntextoLimpio = textoLimpio.replace(/https?:\\/\\/\\S+/g, '[url]');\n\n// Limpiar caracteres especiales manteniendo tildes y ñ\ntextoLimpio = textoLimpio\n    .replace(/[^a-záéíóúñü0-9\\s\\.,]/g, '')\n    .replace(/\\s+/g, ' ') \n    .trim();\n\n// --- DETECCIÓN DE IDIOMA ---\nconst patronesSpamEn = /\\b(login|account|verify|security|urgent|claimed|winner|bank|access)\\b/i;\nconst esIngles = patronesSpamEn.test(mensajeOriginal);\nconst idiomaFinal = esIngles ? 'en' : 'es';\n\n// 3. Respuesta unificada para el siguiente nodo (IA o HTTP Request de borrado)\nreturn {\n    json: {\n        chat_id: chatId,          // Importante para el nodo de borrado\n        message_id: mensajeId,    // Importante para el nodo de borrado\n        cliente_nombre: nombreUsuario,\n        contenido_original: mensajeOriginal,\n        texto_para_ia: textoLimpio || \"sin_contenido\",\n        idioma: idiomaFinal,\n        links: linksRescatados,\n        tiene_links: tieneLinks,\n        fecha_recepcion: new Date().toISOString()\n    }\n};"
      },
