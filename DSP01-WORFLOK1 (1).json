    {
      "parameters": {
        "jsCode": "// Obtenemos todos los ítems que llegan al nodo\nconst items = $input.all();\n\nfor (let i = 0; i < items.length; i++) {\n  // Extraemos el buffer real (los bytes) del objeto binario llamado 'data'\n  const binaryBuffer = await this.helpers.getBinaryDataBuffer(i, 'data');\n  \n  // Creamos una nueva propiedad en el JSON que contiene los bytes puros\n  // Esto es lo que Postgres SI entenderá como imagen (BYTEA)\n  items[i].json.archivo_puro = binaryBuffer;\n}\n\nreturn items;"
      },
